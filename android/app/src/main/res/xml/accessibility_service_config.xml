<?xml version="1.0" encoding="utf-8"?>
<!--
  ClaudeAgentService 접근성 서비스 설정
  - canRetrieveWindowContent=false : 삼성 기기 헤드업 알림 억제 방지
  - packageNames : 차단 대상 앱만 감시 (시스템UI/알림 접근 안 함)
  - flagReportViewIds만 사용, FLAG_RETRIEVE_INTERACTIVE_WINDOWS 미사용
-->
<accessibility-service xmlns:android="http://schemas.android.com/apk/res/android"
    android:accessibilityEventTypes="typeWindowStateChanged"
    android:accessibilityFeedbackType="feedbackGeneric"
    android:notificationTimeout="500"
    android:canRetrieveWindowContent="false"
    android:accessibilityFlags="flagReportViewIds"
    android:packageNames="com.google.android.youtube,com.ss.android.ugc.trill,com.zhiliaoapp.musically,com.instagram.android,com.twitter.android,com.reddit.frontpage,com.discord,tv.twitch.android.app"
    android:description="@string/agent_service_desc" />
